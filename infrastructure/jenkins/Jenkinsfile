pipeline {
    agent any

    parameters {
        string(name: 'AI_QA_OBJECTIVE', defaultValue: 'Verify pet inventory API and place a temporary order to see if inventory updates', description: 'The high-level testing objective / prompt for the Autonomous QA Agent')
        string(name: 'AI_QA_MODEL', defaultValue: 'gemini-2.5-flash', description: 'Google Gemini model to use for the QA Agent')
        booleanParam(name: 'RUN_AI_QA_AGENT', defaultValue: true, description: 'Whether to run the Autonomous AI QA Testing Agent during this build')
    }

    environment {
        // REPLACE this with your actual Docker Hub username in the Jenkins UI or here
        DOCKER_HUB_USER_RAW = "vernondegala"
        DOCKER_CONTEXT = 'default'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Push Images') {
            steps {
                script {
                    def dockerUser = env.DOCKER_HUB_USER_RAW.toLowerCase()
                    def pytestImage = "${dockerUser}/petstore-pytest:${env.BUILD_NUMBER}"
                    def locustImage = "${dockerUser}/petstore-locust:${env.BUILD_NUMBER}"
                    def pytestLatest = "${dockerUser}/petstore-pytest:latest"
                    def locustLatest = "${dockerUser}/petstore-locust:latest"

                    docker.withRegistry('https://index.docker.io/v1/', 'docker-registry-credentials') {
                        
                        echo "Building Pytest image..."
                        def pytestImg = docker.build("${pytestImage}", "-f infrastructure/docker/Dockerfile.pytest .")
                        pytestImg.tag("latest")

                        echo "Building Locust image..."
                        def locustImg = docker.build("${locustImage}", "-f infrastructure/docker/Dockerfile.locust .")
                        locustImg.tag("latest")

                        echo "Pushing images (Build Tag & Latest)..."
                        pytestImg.push()
                        pytestImg.push("latest")
                        locustImg.push()
                        locustImg.push("latest")
                    }
                    
                    env.FINAL_PYTEST_IMAGE = pytestImage
                    env.FINAL_LOCUST_IMAGE = locustImage
                }
            }
        }

        stage('Autonomous AI QA Agent') {
            when {
                expression { params.RUN_AI_QA_AGENT }
            }
            steps {
                script {
                    echo "Checking for GEMINI_API_KEY credential..."
                    try {
                        withCredentials([string(credentialsId: 'gemini-api-key', variable: 'GEMINI_API_KEY')]) {
                            echo "Executing Autonomous AI QA Testing Agent inside the built docker environment..."
                            // Mount workspace tests folder so any generated test cases persist back to the host workspace!
                            sh """
                                docker run --rm \
                                  -v ${WORKSPACE}/tests:/app/tests \
                                  -e GEMINI_API_KEY=${GEMINI_API_KEY} \
                                  ${env.FINAL_PYTEST_IMAGE} \
                                  python agents/cli_runner.py "${params.AI_QA_OBJECTIVE}" --model "${params.AI_QA_MODEL}"
                            """
                        }
                    } catch (Exception e) {
                        echo "⚠️  Failed to execute AI QA Agent: ${e.getMessage()}"
                        echo "Ensure that a 'gemini-api-key' Secret Text credential is configured in Jenkins."
                        // We do not fail the build if the agent fails or key is missing, so functional tests can still run.
                        unstable("AI QA Agent failed or was not configured correctly.")
                    }
                }
            }
        }

        stage('API Tests (Pytest)') {
            steps {
                script {
                    sh "mkdir -p ${WORKSPACE}/reports"
                    // Mount both reports and tests to ensure any auto-generated test files from the AI QA Agent stage are executed!
                    sh "docker run --rm -v ${WORKSPACE}/reports:/app/reports -v ${WORKSPACE}/tests:/app/tests ${env.FINAL_PYTEST_IMAGE}"
                }
            }
            post {
                always {
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports',
                        reportFiles: 'report.html',
                        reportName: 'Pytest API Report',
                        reportTitles: 'Petstore API Test Execution'
                    ])
                }
            }
        }

        stage('Deploy Performance Infrastructure (K8s)') {
            steps {
                script {
                    sh "kubectl apply -f infrastructure/k8s/locust.yaml"
                    sh "kubectl set image deployment/locust-master locust-master=${env.FINAL_LOCUST_IMAGE}"
                    sh "kubectl set image deployment/locust-worker locust-worker=${env.FINAL_LOCUST_IMAGE}"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
