pipeline {
    agent any

    environment {
        // IMPORTANT: You MUST replace 'YOUR_DOCKERHUB_NAMESPACE' with your actual 
        // Docker Hub username/org for the 'docker push' to succeed.
        // Example: DOCKER_HUB_USER = "myusername"
        DOCKER_HUB_USER = "YOUR_DOCKERHUB_NAMESPACE" 
        
        PYTEST_IMAGE = "${DOCKER_HUB_USER}/petstore-pytest:${env.BUILD_NUMBER}"
        LOCUST_IMAGE = "${DOCKER_HUB_USER}/petstore-locust:${env.BUILD_NUMBER}"
        
        // Fixes the "context not found" error on macOS agents
        DOCKER_CONTEXT = 'default'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Push Images') {
            steps {
                script {
                    // This block handles 'docker login' using your Jenkins credentials
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-registry-credentials') {
                        
                        echo "Building Pytest image: ${PYTEST_IMAGE}"
                        def pytestImg = docker.build("${PYTEST_IMAGE}", "-f infrastructure/docker/Dockerfile.pytest .")

                        echo "Building Locust image: ${LOCUST_IMAGE}"
                        def locustImg = docker.build("${LOCUST_IMAGE}", "-f infrastructure/docker/Dockerfile.locust .")

                        echo "Pushing images to Docker Hub..."
                        // These will fail if DOCKER_HUB_USER is not your actual username
                        pytestImg.push()
                        locustImg.push()
                    }
                }
            }
        }

        stage('API Tests (Pytest)') {
            steps {
                script {
                    sh "mkdir -p ${WORKSPACE}/reports"
                    sh "docker run --rm -v ${WORKSPACE}/reports:/app/reports ${PYTEST_IMAGE}"
                }
            }
            post {
                always {
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports',
                        reportFiles: 'report.html',
                        reportName: 'Pytest API Report',
                        reportTitles: 'Petstore API Test Execution'
                    ])
                }
            }
        }

        stage('Deploy Performance Infrastructure (K8s)') {
            steps {
                script {
                    echo "Applying Kubernetes manifests..."
                    sh "kubectl apply -f infrastructure/k8s/locust.yaml"
                    
                    // Update the running deployment with the newly pushed image
                    sh "kubectl set image deployment/locust-master locust-master=${LOCUST_IMAGE}"
                    sh "kubectl set image deployment/locust-worker locust-worker=${LOCUST_IMAGE}"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
