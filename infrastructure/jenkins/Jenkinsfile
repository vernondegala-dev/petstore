pipeline {
    agent any

    environment {
        // Replace with your Docker Hub username
        DOCKER_HUB_USER = "your-dockerhub-username"
        PYTEST_IMAGE = "${DOCKER_HUB_USER}/petstore-pytest:${env.BUILD_NUMBER}"
        LOCUST_IMAGE = "${DOCKER_HUB_USER}/petstore-locust:${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Push Images') {
            environment {
                // Forces Docker to use the local Unix socket instead of looking for 'desktop-linux'
                DOCKER_CONTEXT = 'default'
            }
            steps {
                script {
                    def pytestImageName = "${DOCKER_REGISTRY}/petstore-pytest:${env.BUILD_NUMBER}"
                    def locustImageName = "${DOCKER_REGISTRY}/petstore-locust:${env.BUILD_NUMBER}"

                    // Using the native Docker pipeline plugin
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-registry-credentials') {

                        echo "Building Pytest image..."
                        def pytestImg = docker.build("${pytestImageName}", "-f infrastructure/docker/Dockerfile.pytest .")

                        echo "Building Locust image..."
                        def locustImg = docker.build("${locustImageName}", "-f infrastructure/docker/Dockerfile.locust .")

                        echo "Pushing images to Docker Hub..."
                        pytestImg.push()
                        locustImg.push()
                    }
                }
            }
        }

        stage('API Tests (Pytest)') {
            steps {
                script {
                    // Run pytest in a container and capture results
                    // We pull the image we just pushed to ensure consistency
                    sh "docker run --rm -v ${WORKSPACE}/reports:/app/reports ${PYTEST_IMAGE}"
                }
            }
            post {
                always {
                    publishHTML([allowMissing: false, alwaysLinkToLastBuild: true, keepAll: true, reportDir: 'reports', reportFiles: 'report.html', reportName: 'Pytest API Report', reportTitles: ''])
                }
            }
        }

        stage('Deploy Performance Infrastructure (K8s)') {
            steps {
                script {
                    // Update image names in k8s manifests with the specific build tag and apply
                    sh "sed -i 's|your-docker-repo/petstore-locust:latest|${LOCUST_IMAGE}|g' infrastructure/k8s/locust.yaml"
                    sh "kubectl apply -f infrastructure/k8s/locust.yaml"
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
